{
  "family": "amitha",
  "taskRoleArn": "arn:aws:iam::237494381384:role/ecsTaskExecutionRole",
  "executionRoleArn": "arn:aws:iam::237494381384:role/ecsTaskExecutionRole",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "1024",
  "memory": "3072",
  "runtimePlatform": {
    "cpuArchitecture": "X86_64",
    "operatingSystemFamily": "LINUX"
  },
  "containerDefinitions": [
    {
      "name": "project-6",
      "image": "237494381384.dkr.ecr.us-west-1.amazonaws.com/amitha16@sha256:1da5e196edd6bdc1fd6642aec2f63930bae357cd6a4dd3e28358027700b4cf97",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 80,
          "hostPort": 80,
          "protocol": "tcp",
          "appProtocol": "http",
          "name": "http-80"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/amitha",
          "awslogs-region": "us-west-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
